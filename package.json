{
  "name": "next-license-list",
  "version": "1.0.1",
  "description": "Get list of licenses for third-party packages using in Next.js.",
  "keywords": [
    "webpack",
    "nextjs",
    "next.js",
    "build",
    "oss",
    "open source",
    "compliance",
    "copyright",
    "license",
    "licence",
    "licenses",
    "licences",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/na-trium-144/next-license-list.git"
  },
  "bugs": {
    "url": "https://github.com/na-trium-144/next-license-list/issues"
  },
  "homepage": "https://github.com/na-trium-144/next-license-list#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./generated/*": "./generated/*",
    "./null.json": "./null.json"
  },
  "type": "module",
  "scripts": {
    "build": "tsc"
  },
  "author": "na-trium-144",
  "license": "0BSD",
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@types/node": "^25",
    "next": "^16",
    "typescript": "^5"
  },
  "dependencies": {
    "webpack-license-plugin": "^4"
  }
}
